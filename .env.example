# Flask Configuration
SECRET_KEY=your-secret-key-here-generate-a-random-string
FLASK_ENV=development

# Port Configuration (Azure will set this automatically)
PORT=5000

# Azure AD / Entra ID Authentication (for SharePoint/Graph API access)
AZURE_CLIENT_ID=your-client-app-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=your-directory-tenant-id-here

# Microsoft Entra External ID (for student/resident authentication)
# Leave blank if not using external authentication
ENTRA_CLIENT_ID=your-external-id-client-id
ENTRA_CLIENT_SECRET=your-external-id-client-secret
ENTRA_TENANT_NAME=creditboost
ENTRA_DOMAIN=creditboost.ciamlogin.com
ENTRA_TENANT_ID=your-external-id-tenant-id

# Entra External ID User Flows
ENTRA_SIGNUP_SIGNIN_FLOW=B2C_1_signup_signin
ENTRA_PROFILE_EDIT_FLOW=B2C_1_profile_edit
ENTRA_PASSWORD_RESET_FLOW=B2C_1_password_reset

# Entra External ID Redirect URIs
# Development (use ngrok for local HTTPS testing)
ENTRA_REDIRECT_URI=http://localhost:5000/auth/callback
ENTRA_POST_LOGOUT_REDIRECT_URI=http://localhost:5000/

# Production (update when deploying)
# ENTRA_REDIRECT_URI=https://yourapp.azurewebsites.net/auth/callback
# ENTRA_POST_LOGOUT_REDIRECT_URI=https://yourapp.azurewebsites.net/

# Data Source Configuration
# Set to 'true' to use test data (anonymized), 'false' for production data
USE_TEST_DATA=true

# Future Database Configuration
# DATABASE_URL=postgresql://user:password@host:port/dbname
